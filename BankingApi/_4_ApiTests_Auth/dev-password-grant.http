@host = https://localhost:7010
@tokenEndpoint = {{host}}/connect/token
@devClientId = dev-token-client
@email = admin@mail.local
@password = Geh1m_
@apiScope = banking_api

### 1) Erfolgreicher Dev-Login mit ID-Token + Access-Token + optional Refresh-Token
# Voraussetzung:
# - IdentityAccessServer läuft in Development
# - der Server wurde nach dem Seed einmal neu gestartet
# - der OpenIddict-Client 'dev-token-client' wurde angelegt
POST {{tokenEndpoint}}
Content-Type: application/x-www-form-urlencoded
Accept: application/json

grant_type=dev_password&client_id={{devClientId}}&email={{email}}&password={{password}}&scope=openid profile offline_access {{apiScope}}

> {%
   client.test("Status is 200", function() {
      client.assert(response.status === 200, "Expected HTTP 200");
   });

   client.test("Access token returned", function() {
      client.assert(!!response.body.access_token, "Missing access_token");
   });

   client.test("ID token returned", function() {
      client.assert(!!response.body.id_token, "Missing id_token");
   });

   client.test("Refresh token returned", function() {
      client.assert(!!response.body.refresh_token, "Missing refresh_token");
   });

   client.global.set("refreshToken", response.body.refresh_token);
   client.global.set("accessToken", response.body.access_token);
 %}

### 2) Fehlerfall: falsches Passwort -> invalid_grant
POST {{tokenEndpoint}}
Content-Type: application/x-www-form-urlencoded
Accept: application/json

grant_type=dev_password&client_id={{devClientId}}&email={{email}}&password=wrong-password&scope={{apiScope}}

> {%
   client.test("Status is 400 for invalid credentials", function() {
      client.assert(response.status === 400, "Expected HTTP 400");
   });

   client.test("OpenIddict invalid_grant returned", function() {
      client.assert(response.body.error === "invalid_grant", "Expected invalid_grant");
   });
 %}

### 3) Refresh-Token verwenden
# Führt nur erfolgreich aus, wenn Request 1 zuvor gelaufen ist.
POST {{tokenEndpoint}}
Content-Type: application/x-www-form-urlencoded
Accept: application/json

grant_type=refresh_token&client_id={{devClientId}}&refresh_token={{refreshToken}}

> {%
   client.test("Status is 200 on refresh", function() {
      client.assert(response.status === 200, "Expected HTTP 200");
   });

   client.test("New access token returned", function() {
      client.assert(!!response.body.access_token, "Missing refreshed access_token");
   });
 %}

### 4) Alternative Eingabe mit username statt email
POST {{tokenEndpoint}}
Content-Type: application/x-www-form-urlencoded
Accept: application/json

grant_type=dev_password&client_id={{devClientId}}&username={{email}}&password={{password}}&scope={{apiScope}}

> {%
   client.test("Status is 200 with username parameter", function() {
      client.assert(response.status === 200, "Expected HTTP 200");
   });
 %}

### 5) Alter /dev/token-Endpunkt liefert nur noch Hinweis
POST {{host}}/dev/token
Content-Type: application/json
Accept: application/json

{
  "email": "{{email}}",
  "password": "{{password}}",
  "api": "BankingApi"
}

> {%
   client.test("Deprecated endpoint returns 410", function() {
      client.assert(response.status === 410, "Expected HTTP 410");
   });
 %}

